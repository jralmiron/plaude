# Groq — transcripción con Whisper + formateo con Llama (gratis)
# Consíguela en: https://console.groq.com
GROQ_API_KEY=gsk_...

# Neon PostgreSQL — base de datos serverless (gratis)
# Consíguela en: https://neon.tech → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob — almacenamiento temporal de audio (gratis)
# Local: instala Vercel CLI y ejecuta: vercel env pull .env.local
# En Vercel: se configura automáticamente al añadir Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
